# ----------------------------------------------------------------------------
# DailyOS environment variables
# Copy this file to `.env.local` and fill in the values.
# ----------------------------------------------------------------------------

# --- Supabase ---------------------------------------------------------------
# Found in your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Used for privileged operations (e.g. account data deletion).
# NEVER expose this to the client / commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI provider (OpenAI-compatible) ----------------------------------------
# Works with OpenAI, Together, Groq, OpenRouter, local Ollama, etc.
# Only ever read on the server. Never exposed to the browser.
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_API_KEY=sk-your-key
AI_MODEL=gpt-4o-mini

# --- App --------------------------------------------------------------------
# Used for auth redirects. Set to your deployed URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Private promo / admin codes (server-only) ------------------------------
# The ONLY place the real codes live. Never commit real values. Choose your own
# secret strings. If unset, no plan/admin code works (referral reward codes are
# separate and still work).
#   ADMIN_CODE -> Pro + admin (the /admin console + testing tools)
#   PRO_CODE   -> lifetime Pro     PLUS_CODE -> Plus     FREE_CODE -> reset to Free
ADMIN_CODE=choose-a-secret
PRO_CODE=choose-a-secret
PLUS_CODE=choose-a-secret
FREE_CODE=choose-a-secret

# --- Web Push notifications (opt-in) ----------------------------------------
# Generate a pair once with:  node -e "console.log(require('web-push').generateVAPIDKeys())"
# The public key is safe to expose; keep the private key server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# Optional contact for the push service. Defaults to your site URL — no need to
# set it. If you do, it must be an https: URL or a mailto:.
# VAPID_SUBJECT=https://your-app.vercel.app
# Protects the /api/push/run cron endpoint. Vercel Cron sends this automatically
# when set. Any random string is fine.
CRON_SECRET=some-long-random-string

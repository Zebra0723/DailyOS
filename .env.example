# ----------------------------------------------------------------------------
# DailyOS environment variables
# Copy this file to `.env.local` and fill in the values.
# ----------------------------------------------------------------------------

# --- Supabase ---------------------------------------------------------------
# Found in your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Used for privileged operations (e.g. account data deletion).
# NEVER expose this to the client / commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI provider (OpenAI-compatible) ----------------------------------------
# Works with OpenAI, Together, Groq, OpenRouter, local Ollama, etc.
# Only ever read on the server. Never exposed to the browser.
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_API_KEY=sk-your-key
AI_MODEL=gpt-4o-mini

# --- App --------------------------------------------------------------------
# Used for auth redirects. Set to your deployed URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
